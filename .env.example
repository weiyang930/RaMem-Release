# RaMem environment template
# Copy to .env for local use. Do not commit real secrets.

# OpenAI-compatible API settings
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=
LLM_MODEL=gpt-4.1-mini

# For local vLLM, use for example:
# OPENAI_API_KEY=vllm-local
# OPENAI_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Optional judge override
# JUDGE_API_KEY=your-judge-api-key

# Runtime switches
ENABLE_PLANNING=true
ENABLE_REFLECTION=true
ENABLE_TEMPORAL=true
TEMPORAL_WINDOW_BUFFER_DAYS=5
ANSWER_CONTEXT_MAX_CHARS=0
